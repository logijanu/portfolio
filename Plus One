class Solution {
    public int[] plusOne(int[] digits) {
        int i;
        for(i=digits.length-1;i>=0;i--){
            if(digits[i]+1!=10){
                digits[i]+=1;
                return digits;
            }
            digits[i]=0;
        }
        int[] d=new int[digits.length+1];
        d[0]=1;
        return d;
    }
}
