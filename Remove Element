class Solution {
    public int removeElement(int[] nums, int val) {
        int i,k=0;
        for(i=0;i<nums.length;i++){
            if(nums[i]!=val){
                nums[k]=nums[i];
                k++;
            }
        }
        for(i=k;i<nums.length;i++){
            nums[i]=(int)'_';
        }
        return k;
        }
    }
