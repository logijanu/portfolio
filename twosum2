class Solution {
    public int[] twoSum(int[] numbers, int target) {
        int l=0;
        int r =numbers.length -1;
        int[] a = new int[2];
        while(l < r){
            int sum = numbers[l] + numbers[r];
            if(sum == target){
                break;
            }
            else if(sum > target){
                r--;
            }
            else{
                l++;
            }
        }
        a[0] = l+1;
        a[1] = r+1;
        return a;
    }
}
